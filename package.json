{
  "name": "@instacodeio/icloud-calendar-mcp-server",
  "version": "0.1.4",
  "description": "MCP server for iCloud Calendar via CalDAV",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "icloud-calendar-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "icloud",
    "calendar",
    "caldav"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InstaCode/icloud-calendar-mcp-server.git"
  },
  "homepage": "https://github.com/InstaCode/icloud-calendar-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/InstaCode/icloud-calendar-mcp-server/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ical-generator": "^7.0.0",
    "ical.js": "^2.1.0",
    "tsdav": "^2.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
